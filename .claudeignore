# ===========================================
# .claudeignore - Claude Code コンテキスト除外ファイル
# ===========================================

# -------------------------------------------
# ビルド出力物
# -------------------------------------------
bin/
dist/
tmp/

# -------------------------------------------
# Goモジュールキャッシュ
# -------------------------------------------
vendor/

# -------------------------------------------
# templ生成ファイル
# -------------------------------------------
*_templ.go

# -------------------------------------------
# フロントエンドビルド
# -------------------------------------------
node_modules/
static/dist/

# -------------------------------------------
# SQLiteデータベース
# -------------------------------------------
*.db
*.db-shm
*.db-wal

# -------------------------------------------
# Bleveインデックス
# -------------------------------------------
*.bleve/

# -------------------------------------------
# IDE設定
# -------------------------------------------
.idea/
.vscode/

# -------------------------------------------
# テスト/カバレッジ
# -------------------------------------------
coverage.out
coverage.html

# -------------------------------------------
# Docker
# -------------------------------------------
.docker/

# -------------------------------------------
# Git内部
# -------------------------------------------
.git/

# -------------------------------------------
# OSファイル
# -------------------------------------------
.DS_Store
Thumbs.db

# -------------------------------------------
# Obsidian内部
# -------------------------------------------
content/.obsidian/
