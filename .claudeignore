# ===========================================
# .claudeignore - Claude Code 컨텍스트 제외 파일
# ===========================================

# -------------------------------------------
# 빌드 출력물
# -------------------------------------------
bin/
dist/
tmp/

# -------------------------------------------
# Go 모듈 캐시
# -------------------------------------------
vendor/

# -------------------------------------------
# templ 생성 파일
# -------------------------------------------
*_templ.go

# -------------------------------------------
# 프론트엔드 빌드
# -------------------------------------------
node_modules/
static/dist/

# -------------------------------------------
# SQLite 데이터베이스
# -------------------------------------------
*.db
*.db-shm
*.db-wal

# -------------------------------------------
# Bleve 인덱스
# -------------------------------------------
*.bleve/

# -------------------------------------------
# IDE 설정
# -------------------------------------------
.idea/
.vscode/

# -------------------------------------------
# 테스트/커버리지
# -------------------------------------------
coverage.out
coverage.html

# -------------------------------------------
# Docker
# -------------------------------------------
.docker/

# -------------------------------------------
# Git 내부
# -------------------------------------------
.git/

# -------------------------------------------
# OS 파일
# -------------------------------------------
.DS_Store
Thumbs.db

# -------------------------------------------
# Obsidian 내부
# -------------------------------------------
content/.obsidian/
